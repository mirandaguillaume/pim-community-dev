{
  "name": "@akeneo-pim-community/config",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@akeneo-pim-community/shared": "link:../../../../../front-packages/shared",
    "akeneo-design-system": "link:../../../../../front-packages/akeneo-design-system",
    "react-router-dom": "^6.28",
    "typescript": "^4.0.3"
  },
  "scripts": {
    "app:start": "yarn translation:build && yarn route:build && yarn packages:build && vite",
    "test:unit:run": "jest --config jest.config.js --forceExit --maxWorkers=3 --coverage --coverageDirectory=coverage",
    "test:unit:watch": "jest --config jest.config.js --maxWorkers=3 --watch",
    "lib:build": "tsc -p ./tsconfig.build.json",
    "translation:build": "cp $npm_package_config_application_path/public/js/translation/en_US.js ./src/translations.json",
    "route:build": "cp $npm_package_config_application_path/public/js/fos_js_routes.json ./src/routes.json",
    "packages:build": "yarn --cwd=$npm_package_config_front_packages_path/akeneo-design-system run lib:build && yarn --cwd=$npm_package_config_front_packages_path/shared run lib:build",
    "lint:fix": "prettier --config .prettierrc.json --parser typescript --write \"./src/**/*.{ts,tsx}\"",
    "lint:check": "prettier --config .prettierrc.json --parser typescript --check \"./src/**/*.{ts,tsx}\" && yarn eslint --config .eslintrc.json --max-warnings 0 --ext .tsx,.ts ./src"
  },
  "config": {
    "front_packages_path": "../../../../../front-packages",
    "application_path": "../../../../.."
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^5.11.4",
    "@testing-library/react": "^14.3.0",
    "@testing-library/user-event": "^12.1.10",
    "@types/jest": "^29.0.0",
    "@types/node": "^12.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/styled-components": "^5.1.1",
    "@vitejs/plugin-react": "^4.3.4",
    "prettier": "^2.1.1",
    "ts-jest": "^29.0.0",
    "vite": "^6.4.2"
  },
  "main": "lib/index.js",
  "peerDependencies": {
    "eslint": "^8.57.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styled-components": "^5.1.1"
  }
}
