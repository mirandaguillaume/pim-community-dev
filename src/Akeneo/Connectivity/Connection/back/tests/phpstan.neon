includes:
    - baseline.neon

parameters:
    level: max
    paths:
        - %rootDir%/../../../src/Akeneo/Connectivity/Connection/back
    excludePaths:
        - %rootDir%/../../../src/Akeneo/Connectivity/Connection/back/tests/PhpStan
    ignoreErrors:
        # PHP 8.4: stricter built-in function signatures (only triggered on CI)
        -
            message: '#Parameter \#\d+ \$\w+ of function (implode|array_diff|array_unique|array_intersect) expects#'
            reportUnmatched: false

rules:
    - Akeneo\Connectivity\Connection\Tests\PhpStan\Rule\CoverQueryByIntegrationTestRule
    - Akeneo\Connectivity\Connection\Tests\PhpStan\Rule\FinalControllerRule
    - Akeneo\Connectivity\Connection\Tests\PhpStan\Rule\InvokableControllerRule
    - Akeneo\Connectivity\Connection\Tests\PhpStan\Rule\SuffixControllerByActionRule
    - Akeneo\Connectivity\Connection\Tests\PhpStan\Rule\SuffixExceptionRule
    - Akeneo\Connectivity\Connection\Tests\PhpStan\Rule\SuffixInterfaceRule
    - Akeneo\Connectivity\Connection\Tests\PhpStan\Rule\SuffixTraitRule
