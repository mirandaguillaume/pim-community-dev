parameters:
	ignoreErrors:
		-
			message: '#Call to static method Webmozart\\Assert\\Assert::\w+\(\).*will always evaluate to (true|false)#'
			reportUnmatched: false
		-
			message: '#Instanceof between.*will always evaluate to (true|false)#'
			reportUnmatched: false
		-
			message: '#Call to function (is_string|is_array|is_int|is_null|is_bool)\(\).*will always evaluate to (true|false)#'
			reportUnmatched: false
		-
			message: '#PHPDoc tag.*@return.*has invalid value#'
			reportUnmatched: false
		-
			message: '#return type has no value type specified in iterable type array#'
			reportUnmatched: false
		-
			message: '#Strict comparison using [!=]+ between .* will always evaluate to (true|false)#'
			reportUnmatched: false
		-
			message: '#Parameter .* of class GuzzleHttp\\Psr7\\Request constructor expects#'
			reportUnmatched: false

rules:
	- Akeneo\Connectivity\Connection\Tests\PhpStan\Rule\CoverQueryByIntegrationTestRule
	- Akeneo\Connectivity\Connection\Tests\PhpStan\Rule\FinalControllerRule
	- Akeneo\Connectivity\Connection\Tests\PhpStan\Rule\InvokableControllerRule
	- Akeneo\Connectivity\Connection\Tests\PhpStan\Rule\SuffixControllerByActionRule
	- Akeneo\Connectivity\Connection\Tests\PhpStan\Rule\SuffixExceptionRule
	- Akeneo\Connectivity\Connection\Tests\PhpStan\Rule\SuffixInterfaceRule
	- Akeneo\Connectivity\Connection\Tests\PhpStan\Rule\SuffixTraitRule
