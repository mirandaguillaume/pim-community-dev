includes:
    - %rootDir%/../../../vendor/phpstan/phpstan-webmozart-assert/extension.neon
    - baseline.neon

parameters:
    level: max
    reportUnmatchedIgnoredErrors: false
    paths:
        - %rootDir%/../../../src/Akeneo/Pim/Enrichment/Product/back
    excludePaths:
        analyse:
            - %rootDir%/../../../src/Akeneo/Pim/Enrichment/Product/back/Test
    ignoreErrors:
        # PHP 8.4: GMP/SimpleXMLElement added to built-in function signatures
        -
            message: '#Parameter \#\d+ \$\w+ of function (strval|intval|array_unique|implode|array_diff|array_intersect) expects#'
            reportUnmatched: false
