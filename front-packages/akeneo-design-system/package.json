{
  "name": "akeneo-design-system",
  "version": "0.0.0",
  "description": "Akeneo design system",
  "main": "lib/index.js",
  "scripts": {
    "lib:build": "tsc -p ./tsconfig.build.json",
    "lib:watch": "tsc -p ./tsconfig.build.json --watch",
    "test": "yarn lint:check && yarn test:unit:run && yarn test:visual:run",
    "test:unit:run": "jest --config ./jest.unit.config.js --maxWorkers=3",
    "test:unit:watch": "jest --config ./jest.unit.config.js --watch --maxWorkers=3",
    "test:visual:run": "yarn storybook:build && jest --config ./jest.visual.config.js",
    "test:visual:update": "yarn storybook:build && jest --config ./jest.visual.config.js -u",
    "lint:fix": "prettier --config .prettierrc.json --parser typescript --write \"./{src,generator}/**/*.{ts,tsx}\" && yarn eslint --config .eslintrc.json --quiet \"./src/**/*.{ts,tsx}\" --fix",
    "lint:check": "yarn prettier --config .prettierrc.json --parser typescript --check \"./{src,generator}/**/*.{ts,tsx}\" && yarn eslint --config .eslintrc.json --quiet \"./src/**/*.{ts,tsx}\"",
    "storybook:start": "yarn storybook:copy-public && storybook dev -p 6006",
    "storybook:build": "yarn storybook:copy-public && storybook build",
    "storybook:ci:start": "storybook dev -p 6006 --ci",
    "storybook:copy-public": "cp ./src/__image_snapshots__/*standard-correctly-1-snap.png ./public/"
  },
  "author": "akeneo",
  "license": "OSL-3.0",
  "peerDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styled-components": "^5.1.11"
  },
  "dependencies": {
    "draft-js": "^0.10.5",
    "draftjs-to-html": "^0.8.4",
    "html-to-draftjs": "^1.5.0",
    "react-draft-wysiwyg": "^1.12.13"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "8.6.18",
    "@storybook/addon-actions": "8.6.18",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-links": "8.6.18",
    "@storybook/addon-webpack5-compiler-swc": "^4.0.3",
    "@storybook/blocks": "8.6.18",
    "@storybook/react": "8.6.18",
    "@storybook/react-webpack5": "8.6.18",
    "@testing-library/jest-dom": "^5.11.3",
    "@testing-library/react": "^14.3.0",
    "@testing-library/user-event": "^12.1.9",
    "@types/draft-js": "^0.10.25",
    "@types/draftjs-to-html": "^0.8.0",
    "@types/html-to-draftjs": "^1.4.0",
    "@types/jest": "^29.5.0",
    "@types/jest-image-snapshot": "^3.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-draft-wysiwyg": "^1.12.13",
    "@types/styled-components": "5.1.15",
    "@types/testing-library__jest-dom": "^5.9.2",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.20.6",
    "eslint-plugin-react-hooks": "^4.1.0",
    "glob": "^7.1.6",
    "http-server": "^0.12.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-image-snapshot": "^4.1.0",
    "jest-styled-components": "^7.0.3",
    "prettier": "^3.8.3",
    "react-is": "^18.3.1",
    "react-test-renderer": "^18.3.1",
    "rimraf": "^3.0.2",
    "storybook": "8.6.18",
    "ts-jest": "^29.1.0",
    "tsconfig-paths-webpack-plugin": "^3.3.0",
    "typescript": "^4.1.3",
    "yargs": "^16.0.3"
  },
  "resolutions": {
    "@types/react": "^18.3.0"
  }
}
