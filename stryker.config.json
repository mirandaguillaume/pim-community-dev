{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-js/master/packages/core/schema/stryker-schema.json",
  "testRunner": "jest",
  "jest": {
    "configFile": "jest.stryker.config.js"
  },
  "coverageAnalysis": "perTest",
  "checkers": ["typescript"],
  "tsconfigFile": "tsconfig.json",
  "reporters": ["html", "json", "clear-text", "progress-append-only"],
  "htmlReporter": {
    "fileName": "var/stryker/mutation-report.html"
  },
  "jsonReporter": {
    "fileName": "var/stryker/mutation-report.json"
  },
  "mutate": [
    "front-packages/shared/src/**/*.{ts,tsx}",
    "front-packages/akeneo-design-system/src/**/*.{ts,tsx}",
    "components/identifier-generator/front/src/**/*.{ts,tsx}",
    "src/Akeneo/Category/front/src/**/*.{ts,tsx}",
    "src/Akeneo/Connectivity/Connection/front/src/**/*.{ts,tsx}",
    "src/Akeneo/Connectivity/Connection/workspaces/permission-form/src/**/*.{ts,tsx}",
    "src/Akeneo/Tool/Bundle/MeasureBundle/front/src/**/*.{ts,tsx}",
    "src/Akeneo/Platform/Bundle/CatalogVolumeMonitoringBundle/front/src/**/*.{ts,tsx}",
    "src/Akeneo/Platform/Job/front/process-tracker/src/**/*.{ts,tsx}",
    "!**/*.spec.{ts,tsx}",
    "!**/*.test.{ts,tsx}",
    "!**/__tests__/**",
    "!**/__mocks__/**",
    "!**/test/**",
    "!**/stories/**"
  ],
  "tempDirName": "/tmp/stryker-tmp",
  "thresholds": {
    "high": 80,
    "low": 50,
    "break": 0
  },
  "timeoutMS": 60000
}
