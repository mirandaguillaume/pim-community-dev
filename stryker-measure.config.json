{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker-js/master/packages/core/schema/stryker-schema.json",
  "testRunner": "jest",
  "jest": {
    "configFile": "src/Akeneo/Tool/Bundle/MeasureBundle/front/jest.config.js",
    "enableFindRelatedTests": false
  },
  "checkers": [],
  "tsconfigFile": "tsconfig.json",
  "reporters": ["clear-text", "progress", "json"],
  "jsonReporter": {
    "fileName": "var/stryker/measure-mutation-report.json"
  },
  "incremental": true,
  "incrementalFile": "var/stryker/measure-incremental.json",
  "mutate": [
    "src/Akeneo/Tool/Bundle/MeasureBundle/front/src/**/*.{ts,tsx}",
    "!**/*.test.{ts,tsx}",
    "!**/__tests__/**",
    "!**/__mocks__/**"
  ],
  "ignorePatterns": ["var", "coverage", "/public", "/tools/", ".worktrees", "vendor"],
  "coverageAnalysis": "perTest",
  "timeoutMS": 30000,
  "concurrency": 4,
  "tempDirName": "/tmp/stryker-tmp"
}
