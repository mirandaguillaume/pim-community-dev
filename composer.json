        "akeneo/catalogs": "In order to install one of the Akeneo catalogs"
    },
    "replace": {
        "oro/translation-bundle": "1.0-dev",
        "oro/navigation-bundle": "1.0-dev",
        "oro/security-bundle": "1.0-dev",
        "oro/filter-bundle": "1.0-dev",
        "oro/config-bundle": "1.0-dev",
