        "akeneo/batch-bundle": "0.6.0-dev"
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "symfony/flex": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "composer/package-versions-deprecated": true,
            "infection/extension-installer": true
        },
        "audit": {
            "block-insecure": true,
            "ignore": {
                "PKSA-y2cr-5h3j-g3ys": "Low severity, transitive dep from google/cloud-pubsub. Awaiting google/auth jwt v7 support."
            }
        },
        "platform": {
            "php": "8.4.0"
        }
    },
    "extra": {
        "symfony": {
            "require": "6.4.*"
        }
    }
