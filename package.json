    "@types/luxon": "^1.26.2",
    "@types/node": "18.15.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/react-draft-wysiwyg": "^1.12.13",
    "@types/react-redux": "^7.1.0",
    "@types/styled-components": "^5.1.1",
    "@types/underscore": "^1.9.3",
    "@types/victory": "^33.0.1",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "babel-eslint": "npm:@babel/eslint-parser@^7.25.0",
    "babel-loader": "^8.1.0",
    "babel-minify": "0.5.0",
    "bundle-loader": "0.5.6",
    "colors": "1.3.3",
    "cucumber": "4.0.0",
    "cucumber-html-reporter": "5.0.0",
    "cucumber-junit": "^1.7.1",
    "deepmerge": "^4.2.2",
    "dependency-cruiser": "^11.11.0",
    "eslint": "^8.57.0",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-flowtype": "^8.0.3",
    "eslint-plugin-import": "^2.22.1",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-jsx-a11y": "^6.3.1",
    "eslint-plugin-react": "^7.16.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-testing-library": "^5.11.1",
    "exports-loader": "0.7.0",
    "expose-loader": "^4.0.0",
    "extra-watch-webpack-plugin": "^1.0.3",
    "glob": "7.1.3",
    "imports-loader": "^4.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "jest-watch-typeahead": "^2.2.2",
    "path-browserify": "^1.0.1",
    "prettier": "^2.1.1",
    "react-test-renderer": "^18.3.1",
    "redux-devtools-extension": "^2.13.2",
    "text-loader": "0.0.1",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.5.0",
    "typescript": "^5.7.0",
    "typescript-plugin-styled-components": "^3.0.0",
    "webpack-bundle-analyzer": "^4.10.0",
    "yamljs": "0.3.0",
    "@stryker-mutator/core": "^8.6",
    "@stryker-mutator/jest-runner": "^8.6",
    "@stryker-mutator/typescript-checker": "^8.6"
  },
  "dependencies": {
    "@types/react-query": "^1.2.9",
    "ajv": "^6.14.0",
    "akeneo-design-system": "link:front-packages/akeneo-design-system",
    "backbone": "0.9.10",
    "core-js": "^3.6.5",
    "css-loader": "^3.3.0",
    "dep-diff": "1.0.1",
    "diff": "^5.2.2",
    "formik": "^2.0.6",
    "jquery": "^3.6.0",
    "json-schema-ref-parser": "^7.1.2",
