    "@types/draft-js": "^0.10.25",
    "@types/draftjs-to-html": "^0.8.0",
    "@types/html-to-draftjs": "^1.4.0",
    "@types/jest": "^29.5.0",
    "@types/jquery": "^3.3.31",
